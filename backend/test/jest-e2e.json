{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@libs/database(|/.*)$": "<rootDir>/../libs/database/src/$1",
    "^@libs/decorators(|/.*)$": "<rootDir>/../libs/decorators/src/$1",
    "^@libs/dtos(|/.*)$": "<rootDir>/../libs/dtos/src/$1",
    "^@libs/entities(|/.*)$": "<rootDir>/../libs/entities/src/$1",
    "^@libs/enums(|/.*)$": "<rootDir>/../libs/enums/src/$1",
    "^@libs/guards(|/.*)$": "<rootDir>/../libs/guards/src/$1",
    "^@libs/logger(|/.*)$": "<rootDir>/../libs/logger/src/$1",
    "^@libs/s3(|/.*)$": "<rootDir>/../libs/s3/src/$1",
    "^@libs/types(|/.*)$": "<rootDir>/../libs/types/src/$1",
    "^@libs/utils(|/.*)$": "<rootDir>/../libs/utils/src/$1"
  }
}