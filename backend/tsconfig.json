{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "jsx": "react",
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "strictNullChecks": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "types": [
      "node",
      "express",
      "multer",
      "jest",
      "./.env.d.ts"
    ],
    "paths": {
      "@libs/database": [
        "./libs/database/src"
      ],
      "@libs/database/*": [
        "./libs/database/src/*"
      ],
      "@libs/decorators": [
        "./libs/decorators/src"
      ],
      "@libs/decorators/*": [
        "./libs/decorators/src/*"
      ],
      "@libs/dtos": [
        "./libs/dtos/src"
      ],
      "@libs/dtos/*": [
        "./libs/dtos/src/*"
      ],
      "@libs/email-templates": [
        "./libs/email-templates/src"
      ],
      "@libs/email-templates/*": [
        "./libs/email-templates/src/*"
      ],
      "@libs/emailer": [
        "./libs/emailer/src"
      ],
      "@libs/emailer/*": [
        "./libs/emailer/src/*"
      ],
      "@libs/entities": [
        "./libs/entities/src"
      ],
      "@libs/entities/*": [
        "./libs/entities/src/*"
      ],
      "@libs/enums": [
        "./libs/enums/src"
      ],
      "@libs/enums/*": [
        "./libs/enums/src/*"
      ],
      "@libs/guards": [
        "./libs/guards/src"
      ],
      "@libs/guards/*": [
        "./libs/guards/src/*"
      ],
      "@libs/logger": [
        "./libs/logger/src"
      ],
      "@libs/logger/*": [
        "./libs/logger/src/*"
      ],
      "@libs/s3": [
        "./libs/s3/src"
      ],
      "@libs/s3/*": [
        "./libs/s3/src/*"
      ],
      "@libs/types": [
        "./libs/types/src"
      ],
      "@libs/types/*": [
        "./libs/types/src/*"
      ],
      "@libs/utils": [
        "./libs/utils/src"
      ],
      "@libs/utils/*": [
        "./libs/utils/src/*"
      ]
    }
  }
}