{
	auto_https off
}

http://:80 {

    encode zstd gzip
    header Strict-Transport-Security "max-age=0"
    
    log {
        output file /var/log/caddy/access.log {
            roll_size 64mb
            roll_keep 10
        }
        format json
    }

    @adminer path /adminer* /adminer/*
    handle @adminer {
        uri strip_prefix /adminer
        reverse_proxy short-links-manager-adminer-dev:8080 {
            header_up X-Forwarded-Proto "http"
        }
    }

    @minio path /minio* /minio/*
    handle @minio {
        uri strip_prefix /minio
        reverse_proxy short-links-manager-minio-dev:9001 {
            header_up X-Forwarded-Proto "http"
        }
    }

    @panel path /panel* /panel/*
    handle @panel {
        uri strip_prefix /panel
        reverse_proxy short-links-manager-frontend-dev:4200 {
            header_up X-Forwarded-Proto "http"
        }
    }

    handle_path /* {
        reverse_proxy short-links-manager-backend-dev:3000 {
            header_up X-Forwarded-Proto "http"
        }
    }

}